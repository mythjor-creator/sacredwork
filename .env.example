# Copy this file to .env and fill in real values before running the app.
# Never commit .env to version control.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Database ───────────────────────────────────────────────────────────────────
# Default is SQLite (development). For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/clairbook_prod
DATABASE_URL=

# ── Site URL ───────────────────────────────────────────────────────────────────
# Used for email verification links and GDPR exports. Must include protocol.
SITE_URL=http://localhost:8000

# ── Email ──────────────────────────────────────────────────────────────────────
# Leave EMAIL_HOST empty to use the console backend (prints to stdout in dev).
# Set EMAIL_HOST to enable real SMTP delivery (required in production).
# Production: Mailgun SMTP (recommended) — verify your domain, then use either:
#   A) Generic SMTP variables only
#      EMAIL_HOST=smtp.mailgun.org
#      EMAIL_PORT=587
#      EMAIL_USE_TLS=True
#      EMAIL_USE_SSL=False
#      EMAIL_HOST_USER=postmaster@mg.your-domain.com
#      EMAIL_HOST_PASSWORD=<mailgun-smtp-password>
#   B) Provider shortcut
#      EMAIL_PROVIDER=mailgun
#      MAILGUN_SMTP_LOGIN=postmaster@mg.your-domain.com
#      MAILGUN_SMTP_PASSWORD=<mailgun-smtp-password>
EMAIL_PROVIDER=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# Send waitlist confirmation emails in a background thread so slow SMTP does
# not delay form submissions in production.
WAITLIST_CONFIRMATION_EMAIL_ASYNC=True
MAILGUN_SMTP_HOST=smtp.mailgun.org
MAILGUN_SMTP_PORT=587
MAILGUN_SMTP_LOGIN=
MAILGUN_SMTP_PASSWORD=
# The "From" address on all outgoing mail
DEFAULT_FROM_EMAIL=clairbook <hello@clairbook.com>

# ── Analytics (optional) ───────────────────────────────────────────────────────
# Example: G-XXXXXXXXXX
ANALYTICS_GA4_MEASUREMENT_ID=
# Example: clairbook.com
ANALYTICS_PLAUSIBLE_DOMAIN=
# Optional override if self-hosting plausible script
ANALYTICS_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

# ── Booking Payments (Stripe) ─────────────────────────────────────────────────
# Create keys at https://dashboard.stripe.com/apikeys and webhook endpoint at:
#   https://your-domain.com/payments/webhook/stripe/
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
# If True, booking requests require Stripe checkout; if False, app falls back
# to unpaid booking requests when Stripe is not configured.
BOOKING_REQUIRE_PAYMENT=False

# ── Practitioner Subscriptions (Stripe Billing) ─────────────────────────────
# Keep disabled until launch. When enabled, practitioners can begin annual
# subscription checkout from /billing/.
PRACTITIONER_BILLING_ENABLED=False
# When True, public catalog pages only show practitioners with billing access.
ENFORCE_PRACTITIONER_BILLING_ACCESS=False
# Stripe Price ID for the founding annual plan (ex: price_123)
STRIPE_PRO_FOUNDING_PRICE_ID=
# Optional dedicated webhook secret for /billing/webhook/stripe/
# Defaults to STRIPE_WEBHOOK_SECRET if left empty.
STRIPE_BILLING_WEBHOOK_SECRET=

# ── Production Deployment Checklist ────────────────────────────────────────────
# When deploying to production:
#   1. ✅ Generate a NEW, strong DJANGO_SECRET_KEY (examples below):
#      python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#   2. ✅ Set DEBUG=False
#   3. ✅ Set ALLOWED_HOSTS to your real domain(s):
#      ALLOWED_HOSTS=clairbook.com,www.clairbook.com
#   4. ✅ Set DATABASE_URL for PostgreSQL
#      (Railway auto-injects this when you add the Postgres plugin)
#   5. ✅ Set SITE_URL to your production domain:
#      SITE_URL=https://clairbook.com
#   6. ✅ Configure EMAIL_HOST with real SMTP provider (Mailgun recommended):
#      EMAIL_HOST=smtp.mailgun.org
#      EMAIL_HOST_USER=postmaster@mg.your-domain.com
#      EMAIL_HOST_PASSWORD=<mailgun-smtp-password>
#   7. ✅ Run collectstatic:
#      .venv/bin/python manage.py collectstatic --noinput
#      Commit staticfiles/ to git or upload to CDN.
#   8. ✅ Run migrations:
#      .venv/bin/python manage.py migrate
#   9. ✅ Seed initial data:
#      .venv/bin/python _seed_admin.py
#  10. ✅ Set up SSL/TLS at load balancer (HTTPS must terminate before Django)
#  11. ✅ Configure automated daily database backups
#  12. ✅ Set up error monitoring (Sentry recommended)
#  13. ✅ Test HTTPS redirection and security headers:
#      curl -I https://clairbook.app/  # Check for HSTS, X-Frame-Options headers
#
# For Heroku: See DEPLOYMENT.md for step-by-step instructions
# For VPS: See DEPLOYMENT.md for manual setup guide
# For Docker: See Dockerfile and docker-compose.yml for container deployment

